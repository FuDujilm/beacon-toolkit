# Domains
# Point both records to the production server before starting the HTTP proxy.
OIDC_DOMAIN=id.hamcy.work
BEACON_DOMAIN=beacon.hamcy.work

# Public HTTP origin ports. Put CDN HTTPS in front of these ports.
OIDC_FRONTEND_HTTP_PORT=5000
OIDC_API_HTTP_PORT=5001
BEACON_API_HTTP_PORT=5002
ADMIN_HTTP_PORT=5003

# Source directories on the server.
# Recommended server layout:
#   /opt/beacon/src/OpenOIDC
#   /opt/beacon/src/beacon-api
OPENOIDC_SRC=./src/OpenOIDC
BEACON_API_SRC=./src/beacon-api

# OpenOIDC database
# SQLite data is intentionally not migrated. Production and dev both use PostgreSQL.
OIDC_DATABASE_DRIVER=postgres
OIDC_DATABASE_NAME=openidc
OIDC_DATABASE_USER=openidc
OIDC_DATABASE_PASSWORD=replace-with-long-random-password
OIDC_REDIS_PASSWORD=
OIDC_REDIS_DB=0

# OpenOIDC bootstrap admin
OIDC_ADMIN_EMAIL=admin@example.com
OIDC_ADMIN_PASSWORD=replace-with-long-random-password
OIDC_SECRETS_CLIENT_SECRET_ENCRYPTION_KEY=replace-with-32-byte-random-secret
OIDC_LOG_LEVEL=info
OIDC_LOG_FORMAT=json

# beacon-api database
BEACON_DATABASE_NAME=beacon_api
BEACON_DATABASE_USER=beacon_api
BEACON_DATABASE_PASSWORD=replace-with-long-random-password

# beacon-api auth
BEACON_JWT_SECRET=replace-with-at-least-32-byte-random-secret
BEACON_JWT_ISSUER=beacon-api
BEACON_ACCESS_TOKEN_TTL_SECONDS=3600
BEACON_REFRESH_TOKEN_TTL_SECONDS=2592000
BEACON_ADMIN_MIN_SECURITY_LEVEL=3

# Register this client in OpenOIDC after OpenOIDC starts.
BEACON_OAUTH_CLIENT_ID=beacon-api
BEACON_OAUTH_CLIENT_SECRET=replace-with-openoidc-client-secret

# Optional LLM
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# Optional jobs / logs
SATELLITE_SYNC_ENABLED=true
BEACON_RUST_LOG=beacon_api=info,tower_http=info,axum=info
